#set page(width: auto, height: auto, margin: 8pt)
#grid(
  columns: (auto,) * 4,
  column-gutter: 12pt,
  align: center + horizon,
  [#image("icons/type-check.svg", width: 1.5cm) \ type-check],
  [#image("icons/unit-tests.svg", width: 1.5cm) \ unit-tests],
  [#image("icons/round-trip.svg", width: 1.5cm) \ round-trip],
  [#image("icons/agentic-feature.svg", width: 1.5cm) \ agentic-feature],
)
#v(8pt)
#grid(
  columns: (auto,) * 4,
  column-gutter: 12pt,
  align: center + horizon,
  [#image("icons/type-check.svg", width: 0.5cm)],
  [#image("icons/unit-tests.svg", width: 0.5cm)],
  [#image("icons/round-trip.svg", width: 0.5cm)],
  [#image("icons/agentic-feature.svg", width: 0.5cm)],
)
